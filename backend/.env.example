# MedCity Dashboard Backend — environment variables
# Copy this file to .env and adjust values for your local setup.
# Never commit the actual .env file.

# Origins permitted to call the API (comma-separated, no trailing slash).
# Typical values for local development with React/Vite:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Bot token from @BotFather on Telegram (required for the Telegram bot).
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
