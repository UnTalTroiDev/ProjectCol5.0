# ---------------------------------------------------------------------------
# MedCity Dashboard — environment variables
#
# Copy this file to .env and fill in the values before running the stack:
#   cp .env.example .env
#
# .env is intentionally excluded from version control (.gitignore).
# .env.example IS committed so the team knows which variables are required.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Backend — FastAPI (app/main.py, app/config.py)
# ---------------------------------------------------------------------------

# Comma-separated list of origins allowed by the CORS middleware.
# Add the URL of your frontend here. Defaults to Vite dev server ports.
# Example: ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Dataset CSV cache TTL in seconds (default: 21600 = 6 hours).
# Lower this value during development to re-fetch data more frequently.
# Defined in app/config.py as CSV_CACHE_TTL_SECONDS.
CSV_CACHE_TTL_SECONDS=21600

# Path to the SQLite file used as persistent stale cache (survives restarts).
# In Docker, point this to a mounted volume so the file is not lost.
# STALE_CACHE_DB=/app/data/medata_stale.sqlite3

# Override the URL for the Lesiones Personales dataset (optional).
# Useful if MEData changes the resource ID or you want a local mirror.
# MEDATA_LESIONES_URL=http://medata.gov.co/...

# ---------------------------------------------------------------------------
# WhatsApp Daily Newsletter (backend/app/services/newsletter_service.py)
# ---------------------------------------------------------------------------

# Meta WhatsApp Business Cloud API credentials.
# Create at: https://business.facebook.com/settings/system-users
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# SQLite database for subscriber list and send log.
# In Docker, point to the mounted /app/data volume.
# WHATSAPP_DB=/app/data/whatsapp_subscribers.sqlite3

# Rate limit: max outbound WhatsApp messages per minute.
# WHATSAPP_RATE_LIMIT_PER_MINUTE=30

# Enable the daily newsletter scheduler (default: false).
# NEWSLETTER_ENABLED=true

# Hour of day (0-23) to send the newsletter, in the configured timezone.
# NEWSLETTER_SCHEDULE_HOUR=8

# Timezone for the scheduler (default: America/Bogota).
# NEWSLETTER_TIMEZONE=America/Bogota

# Bearer token required for admin newsletter endpoints (subscriber management, send-now).
# ADMIN_TOKEN=some-secret-token

# ---------------------------------------------------------------------------
# Frontend — Vite / React
# ---------------------------------------------------------------------------

# Base URL of the backend API consumed by the frontend.
# Must be reachable from the browser (not from inside Docker).
# Example: VITE_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
